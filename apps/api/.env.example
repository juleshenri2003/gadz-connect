PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Plateforme RH — e-mails autorisés pour /admin
RH_ALLOWED_EMAILS=jules.henri@ensam.eu

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe Connect (Express accounts)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_RETURN_URL=http://localhost:5173/stripe/return
STRIPE_CONNECT_REFRESH_URL=http://localhost:5173/stripe/refresh

# Facturation Configuration A (SAP + factures PDF)
# Admin — étape ① : SIRET via formalites.entreprises.gouv.fr (code APE 85.59B)
# Admin — étape ② : déclaration SAP sur NOVA → récépissé gratuit (≤ 8 jours ouvrés)
# Admin — étape ③ : habilitation API sur demarche.numerique.gouv.fr → portailapi.urssaf.fr
GADZ_SAP_NUMBER=SAP-XXXXXXXXX
GADZ_PLATFORM_LEGAL_NAME=Gadz'Connect
GADZ_PLATFORM_ADDRESS=Arts et Métiers — Paris, France
GADZ_PLATFORM_SIRET=
GADZ_VAT_APPLICABLE=false
GADZ_BILLING_EMAIL_FROM=facturation@gadzconnect.fr

# Avance immédiate URSSAF (API Tiers de Prestation)
# Désactivé par défaut — activer après habilitation + recette sandbox
URSSAF_API_ENABLED=false
URSSAF_API_MOCK=true
URSSAF_API_BASE_URL=https://api-sandbox.urssaf.fr/tiers-prestation
URSSAF_CLIENT_CERT_PATH=
URSSAF_CLIENT_KEY_PATH=
# Clé 32 octets hex (openssl rand -hex 32) — chiffrement IBAN/NIR au repos
URSSAF_ENCRYPTION_KEY=

# Envoi e-mail (Resend — https://resend.com)
# Test local : clé API + onboarding@resend.dev (expéditeur par défaut).
# Prod : domaine vérifié + GADZ_PLATFORM_EMAIL_FROM + GADZ_APP_URL (URL HTTPS du front).
RESEND_API_KEY=
# Dev local : redirige les e-mails @ensam.eu (comptes fictifs) vers cette boîte.
# Les adresses externes réelles (Gmail, etc.) sont envoyées au destinataire prévu.
RESEND_DEV_INBOX=juleshenri2003@gmail.com
# Optionnel : forcer l'envoi direct même pour des @ensam.eu (liste séparée par des virgules)
# RESEND_DEV_ALLOWLIST=prof.dev@ensam.eu
GADZ_PLATFORM_EMAIL_FROM=
GADZ_APP_URL=
# Relances Stripe Connect (cron) — délai minimum entre deux e-mails (jours)
STRIPE_ONBOARDING_REMINDER_DAYS=3
