PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Plateforme RH — e-mails autorisés pour /admin
RH_ALLOWED_EMAILS=jules.henri@ensam.eu

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe Connect (Express accounts)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_RETURN_URL=http://localhost:5173/stripe/return
STRIPE_CONNECT_REFRESH_URL=http://localhost:5173/stripe/refresh

# Facturation Configuration A (SAP + factures PDF)
GADZ_SAP_NUMBER=SAP-XXXXXXXXX
GADZ_PLATFORM_LEGAL_NAME=Gadz'Connect
GADZ_PLATFORM_ADDRESS=Arts et Métiers — Paris, France
GADZ_PLATFORM_SIRET=
GADZ_VAT_APPLICABLE=false
GADZ_BILLING_EMAIL_FROM=facturation@gadzconnect.fr

# Envoi e-mail (Resend — https://resend.com)
# Test local : clé API + onboarding@resend.dev (expéditeur par défaut).
# Prod : domaine vérifié + GADZ_PLATFORM_EMAIL_FROM + GADZ_APP_URL (URL HTTPS du front).
RESEND_API_KEY=
GADZ_PLATFORM_EMAIL_FROM=
GADZ_APP_URL=
# Relances Stripe Connect (cron) — délai minimum entre deux e-mails (jours)
STRIPE_ONBOARDING_REMINDER_DAYS=3
