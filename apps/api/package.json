{
  "name": "@gadz-connect/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "repair-profiles": "tsx scripts/repair-profiles.ts",
    "seed-demo": "tsx scripts/seed-demo.ts",
    "seed-professor": "tsx scripts/seed-professor.ts",
    "seed-professor-pending": "tsx scripts/seed-professor-pending.ts",
    "apply-migration-005": "tsx scripts/apply-migration-005.ts",
    "seed-student": "tsx scripts/seed-student.ts",
    "align-demo-campus": "tsx scripts/align-demo-campus.ts",
    "apply-migration-008-009": "tsx scripts/apply-migration-008-009.ts",
    "fix-replacement-enums": "tsx scripts/fix-replacement-enums.ts",
    "repair-replacement-notifications": "tsx scripts/repair-replacement-notifications.ts",
    "repair-orphan-slots": "tsx scripts/repair-orphan-slots.ts",
    "repair-demo": "tsx scripts/repair-orphan-slots.ts && tsx scripts/repair-replacement-notifications.ts",
    "seed-replacement-demo": "tsx scripts/seed-replacement-demo.ts"
  },
  "dependencies": {
    "@gadz-connect/types": "workspace:*",
    "@supabase/supabase-js": "^2.47.10",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "pdfkit": "^0.16.0",
    "stripe": "^17.5.0",
    "ws": "^8.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@gadz-connect/config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.13.8",
    "@types/ws": "^8.18.1",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
}
