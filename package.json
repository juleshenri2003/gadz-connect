{
  "name": "gadz-connect",
  "private": true,
  "version": "0.1.0",
  "description": "Plateforme inter-campus Gadz'Connect",
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:web": "pnpm --filter @gadz-connect/web dev",
    "dev:api": "pnpm --filter @gadz-connect/api dev",
    "build": "pnpm run -r build",
    "build:web": "pnpm --filter @gadz-connect/web build",
    "build:api": "pnpm --filter @gadz-connect/api build",
    "lint": "pnpm run -r lint",
    "typecheck": "pnpm run -r typecheck",
    "clean": "pnpm run -r clean && rm -rf node_modules"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
}
